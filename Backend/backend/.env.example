# Environment Configuration Template
# Copy this file to .env and fill in the actual values

# Application Environment
ENVIRONMENT=development  # Options: development, staging, production
DEBUG=True
SECRET_KEY=your-secret-key-here-change-this-use-at-least-50-characters-long-random-string

# Security Settings (for production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database Configuration
DB_NAME=fusion_db
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=5432

# Redis Configuration
REDIS_URL=redis://127.0.0.1:6379/1

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@fusion.edu
SERVER_EMAIL=server@fusion.edu

# Security Settings
DJANGO_LOG_LEVEL=INFO

# JWT Settings (optional overrides)
# JWT_ACCESS_TOKEN_LIFETIME=2  # hours
# JWT_REFRESH_TOKEN_LIFETIME=7  # days

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_RATE=100/hour

# Login Lockout
LOGIN_LOCKOUT_ENABLED=True
MAX_FAILED_LOGIN_ATTEMPTS=5
FAILED_LOGIN_ATTEMPT_DURATION=300  # seconds

# Monitoring (optional)
SENTRY_DSN=

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Timezone
TIME_ZONE=Asia/Kolkata